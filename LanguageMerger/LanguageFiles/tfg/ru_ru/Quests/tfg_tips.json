{
    //#region Starting
    "quests.tfg_tips": "Советы TerraFirmaGreg",
    "quests.tfg_tips.subtitle": "Подсказки и хитрости, чтобы жизнь стала немного проще.",

    "quests.tfg_tips.beginning.title": "Здесь живут советы и хитрости!",
    "quests.tfg_tips.beginning.subtitle": "Господи, да тут же ветвлений хоть отбавляй...",
    "quests.tfg_tips.beginning.desc": "Эта глава даёт вам много, &o(и мы действительно имеем в виду — много)&r советов по выживанию и процветанию.\n\nКаждая ветка квестов представляет крупные моды в &2TerraFirmaGreg&r и содержит полезные советы по их эффективному использованию. Ни один из этих квестов не обязателен для прохождения, хотя некоторые &oмогут&r быть заблокированы до выполнения основных заданий.",
    //#endregion

    //#region Portable Storage
    "quests.tfg_tips.portable_storage.title": "Портативные решения для хранения",
    "quests.tfg_tips.portable_storage.subtitle": "Оказывается, инвентарь у тебя довольно мал.",
    "quests.tfg_tips.portable_storage.desc": "В путешествиях ты можешь исследовать очень &olot&r и набрать много хлама. Эта ветка квестов предлагает несколько способов расширить твой переносной инвентарь.",

    "quests.tfg_tips.toolbelt.title": "Пояс инструментов и сумки",
    "quests.tfg_tips.toolbelt.subtitle": "Эти инструменты занимают слишком много места, давай это исправим!",
    "quests.tfg_tips.toolbelt.desc": "С &dПоясом инструментов&r ты сможешь управлять несколькими инструментами, не занимая слоты в инвентаре! Этот полезный предмет вставляется в специальный &3слот пояса&r в меню &4Curios&r. Можно вставлять и доставать инструменты с помощью &ckeybind.&r В начале доступно только два слота, но их можно увеличить, добавляя &aСумки на пояс&r.\n\n&lИз-за бага этого мода, нельзя улучшить &dПояс инструментов&f, если он покрашен или в нём есть инструменты. Сначала опустоши его!",

    "quests.tfg_tips.maxed_out_toolbelt.title": "ВСЕ ИНСТРУМЕНТЫ",
    "quests.tfg_tips.maxed_out_toolbelt.subtitle": "Этот пояс сейчас, наверное, очень тяжёлый...",
    "quests.tfg_tips.maxed_out_toolbelt.desc": "В &dПояс инструментов&r можно вставить 7 дополнительных сумок, итого 9 инструментов в одном поясе!",
    "quests.tfg_tips.maxed_out_toolbelt.task": "Получить максимальный пояс инструментов.",

    "quests.tfg_tips.vessels.title": "Большие и маленькие сосуды",
    "quests.tfg_tips.vessels.subtitle": "Глина может быть очень полезной",
    "quests.tfg_tips.vessels.desc": "&dМаленькие сосуды&r имеют 4 слота в инвентаре, а &6Большие сосуды&r — 9! Маленькие сосуды нужны не только для хранения предметов, но и для плавки и сплавления базовых металлов.\n&6Большие сосуды&r тяжелее носить, но отлично подходят для хранения еды.\n\n&l&3Подсказка:&r&o Большие сосуды — это одновременно и ранние рюкзаки!",

    "quests.tfg_tips.portable_cells.title": "Портативные ячейки для предметов и жидкостей",
    "quests.tfg_tips.portable_cells.subtitle": "Это не слишком сложно?",
    "quests.tfg_tips.portable_cells.desc": "С &dApplied Energistics 2&r можно создавать &aПортативные ячейки для предметов&r и &bжидкостные ячейки&r, позволяющие хранить большие объёмы предметов и жидкостей в виде данных. К сожалению, &dApplied Energistics 2&r доступен только после &6HV&r, так что до этого придётся подождать.",

    "quests.tfg_tips.256m_portable_cells.title": "МЕГА портативные ячейки для предметов и жидкостей",
    "quests.tfg_tips.256m_portable_cells.subtitle": "Когда килобайт мало",
    "quests.tfg_tips.256m_portable_cells.desc": "С &dМЕГА ячейками&r можно создавать ячейки с &lогромным&r объёмом данных!\n\n&l&3Забавный факт:&r&o Одна 256M портативная ячейка для предметов может хранить до миллиарда одного типа предметов! Этого хватит, чтобы заполнить более 58 тысяч сундуков!",

    "quests.tfg_tips.backpack_materials.title": "Материалы для рюкзака",
    "quests.tfg_tips.backpack_materials.subtitle": "Спальный мешок не входит в комплект",
    "quests.tfg_tips.backpack_materials.desc": "&3Сложный рюкзак&r — главный способ увеличить размер переносного инвентаря. Первый уровень удваивает обычный инвентарь, а последующие уровни увеличивают его ещё больше! Кроме того, есть множество &aфункциональных улучшений&r, а разные части рюкзака можно красить в разные цвета!",

    "quests.tfg_tips.first_backpack.title": "Твой первый рюкзак",
    "quests.tfg_tips.first_backpack.subtitle": "Нет, карта не появится волшебным образом.",
    "quests.tfg_tips.first_backpack.desc": "Это твой первый &3Сложный рюкзак.&r В нём всего &c27&r слотов инвентаря и можно вставить &aодно улучшение.&r Посмотри следующие две ветки, чтобы узнать про инвентарь и улучшения рюкзака.",

    "quests.tfg_tips.red_steel_backpack.title": "Рюкзак из красной стали",
    "quests.tfg_tips.red_steel_backpack.subtitle": "Круче, чем рюкзак из синей стали",
    "quests.tfg_tips.red_steel_backpack.desc": "Рюкзак из &4красной стали&r — это твоё первое настоящее улучшение рюкзака. В нём &c54&r слота и можно вставить &aдва улучшения.&r",

    "quests.tfg_tips.aluminium_backpack.title": "Рюкзак из алюминия",
    "quests.tfg_tips.aluminium_backpack.subtitle": "Это алюминий или алюминий?",
    "quests.tfg_tips.aluminium_backpack.desc": "Рюкзак из &bалюминия&r — второе настоящее улучшение рюкзака. В нём &c81&r слот и можно вставить &aтри улучшения.&r",

    "quests.tfg_tips.titanium_backpack.title": "Титановый рюкзак",
    "quests.tfg_tips.titanium_backpack.subtitle": "Почти Титаник.",
    "quests.tfg_tips.titanium_backpack.desc": "Рюкзак из &5титана&r — третье настоящее улучшение рюкзака. В нём &c108&r слотов и можно вставить &aпять улучшений.&r",

    "quests.tfg_tips.tungstensteel_backpack.title": "Рюкзак из вольфрамовой стали",
    "quests.tfg_tips.tungstensteel_backpack.subtitle": "Лучший рюкзак.",
    "quests.tfg_tips.tungstensteel_backpack.desc": "Рюкзак из &9вольфрамовой стали&r — последнее улучшение рюкзака. В нём целых &c120&r слотов и можно вставить &aсемь улучшений!&r",

    "quests.tfg_tips.backpack_upgrades.title": "Улучшения рюкзака",
    "quests.tfg_tips.backpack_upgrades.subtitle": "Больше, чем просто рюкзак",
    "quests.tfg_tips.backpack_upgrades.desc": "&aУлучшения рюкзака&r можно вставлять в &3Сложные рюкзаки&r, чтобы дать рюкзаку новые способности и функции.\n\nДля их создания потребуется &bсталь&r.",

    "quests.tfg_tips.crafting_upgrade.title": "Улучшение для крафта",
    "quests.tfg_tips.crafting_upgrade.subtitle": "Верстак на ходу!",
    "quests.tfg_tips.crafting_upgrade.desc": "&aУлучшение для крафта&r позволяет носить &3Верстак&r в рюкзаке где угодно. Ты удивишься, как жил без этого раньше!",

    "quests.tfg_tips.advanced_upgrades.title": "Продвинутые улучшения",
    "quests.tfg_tips.advanced_upgrades.subtitle": "Жёлтые улучшения",
    "quests.tfg_tips.advanced_upgrades.desc": "Некоторые улучшения рюкзака имеют версии &eПродвинутых улучшений&r. У них больше функций, например, дополнительные типы фильтров или расширенная настройка.\nПопробуй создать &aФильтр&r и &eПродвинутый фильтр&r, чтобы выполнить этот квест.",

    "quests.tfg_tips.all_backpack_upgrades.title": "ВСЕ УЛУЧШЕНИЯ",
    "quests.tfg_tips.all_backpack_upgrades.subtitle": "Ты даже не сможешь уместить всё это в одном рюкзаке...",
    "quests.tfg_tips.all_backpack_upgrades.desc": "Вот все улучшения, которые есть у &3Сложных рюкзаков&r. Смогёшь ли ты сделать их все?",
    //#endregion

    //#region GT
    "quests.tfg_tips.gt.title": "GregTech",
    "quests.tfg_tips.gt.subtitle": "В конце концов, одна треть названия модпака.",
    "quests.tfg_tips.gt.desc": "&3GregTech&r может быть довольно устрашающим, этот раздел квестов должен помочь вам.",

    "quests.tfg_tips.nano_saber.title": "Нано Сабля",
    "quests.tfg_tips.nano_saber.subtitle": "26 урона при активации!",
    "quests.tfg_tips.nano_saber.desc": "&6Нано Сабля&r — мощное оружие, которое вы сможете разблокировать, достигнув уровня &5EV&r. Просто нажмите &dShift + Правый Клик&r, чтобы активировать режим &cбззззз&r.",

    "quests.tfg_tips.gt_tools.title": "Инструменты GregTech",
    "quests.tfg_tips.gt_tools.subtitle": "",
    "quests.tfg_tips.gt_tools.desc": "Большинство инструментов &5GregTech&r создаются из &6головок инструментов&r. Попробуйте использовать &aEMI&r, чтобы изучить, что с ними можно делать — просто запомните два важных момента:\n\n- Чем выше уровень &eголовки инструмента&r, тем мощнее будет &cинструмент&r и тем больше энергии он потребляет &6батареи&r.\n- Не каждый инструмент поддерживает все уровни головок. Например, &6бензопила&r может быть сделана только с головкой &7LV&r.",

    "quests.tfg_tips.magnets.title": "Магниты для предметов",
    "quests.tfg_tips.magnets.subtitle": "",
    "quests.tfg_tips.magnets.desc": "&6Магнит для предметов&r — именно то, что вы ожидаете — магнит, который притягивает к вам ближайшие &6предметы&r. &aОчень полезно&r. Что еще можно желать?",
    //#endregion

    "quests.tfg_tips.terrafirmacraft.title": "Дополнения TerraFirmaCraft",
    "quests.tfg_tips.terrafirmacraft.subtitle": "Оставшиеся две трети названия модпака",
    "quests.tfg_tips.terrafirmacraft.desc": "&3TerraFirmaCraft&r — один из основных модов в &2TerraFirmaGreg.&r Эта ветка в основном посвящена некоторым его выживательным функциям и другим &dдополнениям&r модпака, таким как &4Стареющий алкоголь&r и &bТрости.&r",
  
    "quests.tfg_tips.cane.title": "Трости для ходьбы",
    "quests.tfg_tips.cane.subtitle": "Можно даже стегать людей!",
    "quests.tfg_tips.cane.desc": "&dТрость&r позволяет полностью игнорировать любые блоки, замедляющие движение, такие как &asнег&r, пока вы держите её в &cглавной&r или &cвторичной руке.&r\nВ качестве бонуса она &bповышает высоту шага.&r Другими словами, позволяет подниматься на один блок без прыжка. &dЖелезная трость&r даже позволяет ходить по заборам!",
    "quests.tfg_tips.cane.task": "Любая трость",
  
    "quests.tfg_tips.glassblowing.title": "Выдувание стекла",
    "quests.tfg_tips.glassblowing.subtitle": "Реалистичная работа со стеклом!",
    "quests.tfg_tips.glassblowing.desc": "Чтобы сделать любые &dстеклянные панели&r или &dблоки&r, вам понадобится установка для &3выдувания стекла&r.\n\n&3Выдувание&r требует &aдуховой трубки&r и платформы из блоков для выдувания, куда заливается расплавленное стекло. Посмотрите &2Полевое руководство&r для информации о форме платформы и подходящих блоках. Вы получите доступ к выдуванию стекла, как только сможете формовать &aлатунь!&r",
    "quests.tfg_tips.glassblowing.task.1": "Любые блоки для выдувания стекла.",
  
    "quests.tfg_tips.glassblowing_tools.title": "Инструменты для выдувания стекла",
    "quests.tfg_tips.glassblowing_tools.subtitle": "Инструменты ремесла",
    "quests.tfg_tips.glassblowing_tools.desc": "Для работы со &dстеклом&r понадобится множество инструментов.\n\n&3Лопатка&r: Делает выравнивание, используется для создания &dстеклянных панелей&r и &dстеклянных ламп.&r\n&3Каменный пила&r: Обязательна для производства стеклянных изделий, может подбирать &dстекло&r и &cкаменные бутоны&r в мире, как эффект &bШёлковое касание&r!\n&3Захваты&r: Используются для щипков стекла, преимущественно для контейнеров, таких как &dстеклянные бутылки.&r\n&3Шерстяная ткань&r: Применяется для прокатки стекла, нужна для &dлинз&r и &dбанок.&r",
  
    "quests.tfg_tips.glass_blocks.title": "Стеклянные блоки",
    "quests.tfg_tips.glass_blocks.subtitle": "Возьмите себе оконные блоки.",
    "quests.tfg_tips.glass_blocks.desc": "В зависимости от типа песка, используемого для &aпартии стекла&r, ваше конечное &dстекло&r будет иметь разные цвета. Ознакомьтесь с разделом &2Полевого руководства&r о &3выдувании стекла&r, чтобы узнать другие способы получения цветов. Позже вы сможете использовать химикаты из &3Gregtech&r для легкой окраски стекла.\n\n&3&lСовет:&r&o Если вы хотите сделать много стеклянных блоков и имеете &bплавильню сплавов&f, эффективнее делать &dстеклянные панели&f, затем &bизмельчать&f их, создавать из этого &dпыль&f и использовать &aформу для блоков&f, так как одна партия может дать до 16 мелких пылей сразу!",
  
    "quests.tfg_tips.lamps.title": "Лампы",
    "quests.tfg_tips.lamps.subtitle": "Они красивые.",
    "quests.tfg_tips.lamps.desc": "Как и в обычном Майнкрафте, &dлампы&r можно подвешивать к потолку с помощью цепей или ставить на блоки. &dЛампы&r потребляют разные виды топлива, чтобы гореть. Некоторые топлива горят &4бесконечно.&r\n\n&3&lСовет:&r&o заполненные лампы можно поместить в &6слот назад&f в меню &cКурьёзов&f для динамического освещения без рук. Это может не работать с включёнными шейдерами.",
  
    "quests.tfg_tips.creosote.title": "Топливо для ламп: Кремний",
    "quests.tfg_tips.creosote.subtitle": "Если у вас его много...",
    "quests.tfg_tips.creosote.desc": "&dКремний&r можно использовать как топливо для лампы, но полный бак горит всего &c10&r дней.",
    "quests.tfg_tips.creosote.task": "Ведро кремния",
  
    "quests.tfg_tips.tallow.title": "Топливо для ламп: Талловое масло",
    "quests.tfg_tips.tallow.subtitle": "Животный жир",
    "quests.tfg_tips.tallow.desc": "&dТалловое масло&r можно использовать как топливо для ламп. Полная лампа горит &c18&r дней.",
    "quests.tfg_tips.tallow.task": "Ведро таллового масла",
  
    "quests.tfg_tips.olive_oil.title": "Топливо для ламп: Оливковое масло",
    "quests.tfg_tips.olive_oil.subtitle": "Немного оливкового масла",
    "quests.tfg_tips.olive_oil.desc": "&dОливковое масло&r можно использовать как топливо для ламп, и хотя оно сложнее в производстве, полная лампа горит целых &c83&r дня!\n\n&3&lСовет:&r&o Доступ к электрическим машинам даже на &7низком уровне&f облегчит процесс.",
    "quests.tfg_tips.olive_oil.task": "Ведро оливкового масла",
  
    "quests.tfg_tips.lava_lamp.title": "Топливо для ламп: Лава?",
    "quests.tfg_tips.lava_lamp.subtitle": "Не такое завораживающее, как настоящее",
    "quests.tfg_tips.lava_lamp.desc": "С очень жаропрочной сталью &9Синяя сталь&r можно сделать &dЛампу из синей стали.&r В неё можно залить &cлаву&r, получив бесконечный источник света, но только из одного материала лампы.\n\nОсторожно с заполненной лампой с лавой, она очень &cгорячая...&r",
  
    // TODO: add quest
    "quests.tfg_tips.glowstone_lamp.title": "Топливо для лампы: Светокамень",
    "quests.tfg_tips.glowstone_lamp.subtitle": "Лучшее топливо для лампы",
    "quests.tfg_tips.glowstone_lamp.desc": "Вам потребуется доступ к электричеству не ниже &7LV&r, чтобы расплавить &dСветокамень&r, но если вам нравится внешний вид &lany&r лампы, вы можете использовать &6Жидкий Светокамень&r для её бесконечного питания. В отличие от &cЛавы&r, он не горячий!",
  
    "quests.tfg_tips.charcoal_pile.title": "Куча древесного угля",
    "quests.tfg_tips.charcoal_pile.subtitle": "Это вам пригодится",
    "quests.tfg_tips.charcoal_pile.desc.1": "&aКучи древесного угля&r — это источник &dугля&r на ранних этапах игры. Он вам понадобится &oочень много&r, если хотите добиться успеха в &2TFG&r, ведь древесный уголь важен для &3металлообработки&r и плавки &3заготовок&r для &bковкого железа&r.\n\nНачните с выкапывания ямы.",
    "quests.tfg_tips.charcoal_pile.desc.2": "После создания ямы, размещайте бревна по выбору, удерживая &cприсесть&r — так вы положите &2кучи бревен&r в яму. Чем больше бревен в куче, тем больше &dугля&r получится.",
    "quests.tfg_tips.charcoal_pile.desc.3": "После размещения &2куч бревен&r накройте их блоками, оставив &oодин открытым&r. Подожгите этот открытый блок с помощью &dЗажигалки&r, брошенного &eФакела&r или &4Огнива&r. Ждите появления больших дымовых частиц из накрывающих блоков, чтобы &cзапечатать&r открытый блок. Когда дым прекратится, снимите накрытие и соберите &dдревесный уголь&r, лучше всего лопатой &aЛопатой&r или &aСовком&r.",
    "quests.tfg_tips.charcoal_pile.desc.4": "&3&lПолезный совет:&r&o Рекомендуется рано вложиться в &3Коксохимическую печь&f. Она не только производит &aуголь&f из бревен с &cлучшей отдачей&f, но и даёт &aКреозот&f — полезное топливо для ламп и паровой энергии, а также &aКокс&f для производства &dстали&f.",
  
    "quests.tfg_tips.thatch_bed.title": "Койка из соломы",
    "quests.tfg_tips.thatch_bed.subtitle": "Место для отдыха... так себе",
    "quests.tfg_tips.thatch_bed.desc": "Используя немного &bсоломы&r и &aкрупной необработанной шкуры&r, вы можете создать &dКойку из соломы.&r В ней нельзя спать, но она &cустанавливает точку возрождения.&r\n\nЧтобы сделать койку, положите &bдва блока соломы&r рядом, затем взаимодействуйте с ними, удерживая &aкрупную необработанную шкуру.&r",
    "quests.tasktype.looktat": "Посмотреть на готовую койку из соломы",
  
    "quests.tfg_tips.loom.title": "Ткацкий станок",
    "quests.tfg_tips.loom.subtitle": "Если хочешь спать, придётся потрудиться...",
    "quests.tfg_tips.loom.desc": "Чтобы сделать лучшую кровать, нужно создавать ткани. &3Ткацкий станок&r — рабочее место для этого, позволяющее делать различные ткани с разными назначениями.",
  
    "quests.tfg_tips.burlap_cloth.title": "Мешковина",
    "quests.tfg_tips.burlap_cloth.subtitle": "Сделана из джута!",
    "quests.tfg_tips.burlap_cloth.desc": "Замочив &aджут&r в бочке и обработав полученное &aджутовое волокно&r на &3ткацком станке&r, вы создадите &dмешковину.&r\n\nМешковина используется для создания &bмешковой одежды&r, защищающей от &cжарких условий&r, &eпчеловодческой брони&r против агрессивных пчёл и других полезных вещей.",
  
    "quests.tfg_tips.pineapple_leather.title": "Ананасовая кожа",
    "quests.tfg_tips.pineapple_leather.subtitle": "Кто живёт в ананасе под водой?",
    "quests.tfg_tips.pineapple_leather.desc": "Получив &aананасовые волокна&r, &bпротягивая&r их в &aананасовую пряжу&r и обработав на &3ткацком станке&r, вы получите &dананасовую кожу&r — экологически чистый аналог для &bкожаных изделий.&r",
  
    "quests.tfg_tips.wool_cloth.title": "Шерстяная ткань",
    "quests.tfg_tips.wool_cloth.subtitle": "Беее...",
    "quests.tfg_tips.wool_cloth.desc": "Стригите дружелюбных &2животных, дающих шерсть&r, чтобы получить шерсть, которую можно прядить в &dшерстяную пряжу.&r Обработав пряжу на &3ткацком станке&r, вы получите &dшерстяную ткань.&r\n\nКроме использования в &bстеклоделии&r, её можно применять для изготовления &aшерстяной одежды&r, идеально подходящей для &bхолодных&r и суровых условий.\n\nШерсть считается &bвысококачественной тканью.&r",
  
    "quests.tfg_tips.silk_cloth.title": "Шёлковая ткань",
    "quests.tfg_tips.silk_cloth.subtitle": "Очень, очень гладкая.",
    "quests.tfg_tips.silk_cloth.desc": "&dШёлковая ткань&r создаётся из &aнитей&r, получаемых при убийстве &bпауков&r, или из &bинготов полиамидов (нейлона)&r. Пока нет шелкопрядов, увы! Опасный биом &cПаутиное логово&r в &4Подземельях&r — другой источник, но рискованный.\n\nШёлковая ткань нужна для создания &aшёлковой одежды&r, которая лучше всего защищает от &cжары&r.\n\nШёлк считается &bвысококачественной тканью.&r",
  
    "quests.tfg_tips.unrefined_paper.title": "Неочищенная бумага",
    "quests.tfg_tips.unrefined_paper.subtitle": "Время сделать историю.",
    "quests.tfg_tips.unrefined_paper.desc": "&aНеочищенная бумага&r — это шаг к настоящей &dбумаге.&r Существует множество способов изготовления бумаги — одни проще, другие сложнее, в зависимости от ресурсов. Загляните в раздел &bбумагоделия&r в вашем &2Полевом путеводителе!&r",
  
    "quests.tfg_tips.bed.title": "Кровати",
    "quests.tfg_tips.bed.subtitle": "Отдохни душой усталой.",
    "quests.tfg_tips.bed.desc": "Используя &bвысококачественную ткань&r, такую как &aшерсть&r или &aшёлковая ткань&r, вы можете создать &dкровать.&r В отличие от &2койки из соломы&r, настоящая &dкровать&r достаточно удобна, чтобы спать в ней всю ночь. Сладких снов!",
  
    "quests.tfg_tips.sleeping_bags.title": "Спальные мешки",
    "quests.tfg_tips.sleeping_bags.subtitle": "Ночная вечеринка!",
    "quests.tfg_tips.sleeping_bags.desc": "&dСпальный мешок&r — предмет для &bсна ночью.&r В отличие от кроватей, он &oне&r устанавливает вашу &cточку возрождения.&r",
  
    "quests.tfg_tips.hammocks.title": "Гамаки",
    "quests.tfg_tips.hammocks.subtitle": "Для тех, кто бодрствует ночью",
    "quests.tfg_tips.hammocks.desc": "&dГамак&r делает противоположное &2спальному мешку&r — позволяет спать днём. Идеально для долгих рецептов бочек или куч древесного угля.\nКак и &2спальные мешки&r, они &oне&r устанавливают вашу &cточку возрождения.&r",
  
    "quests.tfg_tips.panning.title": "Промывка",
    "quests.tfg_tips.panning.subtitle": "Переживите золотую лихорадку заново!",
    "quests.tfg_tips.panning.desc": "На берегах рек вы можете заметить гравий с небольшими вкраплениями минералов — &aместорождения природной руды.&r Правый клик по ним с &bковшом&r позволит переработать руду в &dмаленькие кусочки природных руд.&r Это пригодится, если не хватает немного миллилитров для заливки формы.",
  
    "quests.tfg_tips.sluice.title": "Водяные желоба",
    "quests.tfg_tips.sluice.subtitle": "Промывка на стероидах",
    "quests.tfg_tips.sluice.desc": "&3Водяной желоб&r помогает переработать &aгравий&r быстрее и частично автоматически. К тому же желоба могут давать &dредкие побочные продукты&r, смотрите раздел &2Полевой путеводитель&r для подробностей!",
  
    "quests.tfg_tips.status_effects.title": "Эффекты состояния",
    "quests.tfg_tips.status_effects.subtitle": "Больше никаких странных зелий.",
    "quests.tfg_tips.status_effects.desc": "Пока варка зелий недоступна, можно создавать другие съедобные предметы для получения эффектов состояния.",
  
    "quests.tfg_tips.aged_alcohol.title": "Выдержанный алкоголь",
    "quests.tfg_tips.aged_alcohol.subtitle": "Пейте умеренно...",
    "quests.tfg_tips.aged_alcohol.desc": "&3Выдержка алкогольных напитков&r в &aбочках&r повышает их крепость, получая &dвыдержанный алкоголь&r. При употреблении из бутылок или фляжек они дают полезные эффекты, такие как &bрегенерация&r, &bсопротивление&r или &bпоглощение&r. Особенно полезно для исследований.",
    "quests.tfg_tips.aged_alcohol.task": "Любой выдержанный алкоголь",
  
    "quests.tfg_tips.pills.title": "Медицина: таблетки",
    "quests.tfg_tips.pills.subtitle": "Таблетки тут!",
    "quests.tfg_tips.pills.desc": "Смешивание &aвоска&r, &bродниковой воды&r и уникальных ингредиентов даёт &dтаблетки!&r Они дают множество разных эффектов — как хороших, так и плохих.\n\n&3&lСовет:&r&o Использование &bмеханического миксера&f или &bGT миксера&f удваивает выход!",
    "quests.tfg_tips.pills.task": "Любая таблетка с эффектом",
  
    "quests.tfg_tips.tablets.title": "Медицина: пилюли",
    "quests.tfg_tips.tablets.subtitle": "Пилюли тут...?",
    "quests.tfg_tips.tablets.desc": "Пилюли сложнее в изготовлении, требуют &3Большой механический миксер&r или &3GT миксер&r, но &dдействуют дольше&r.",
    "quests.tfg_tips.tablets.task": "Любая пилюля",
  
    "quests.tfg_tips.salvo.title": "Медицина: мази",
    "quests.tfg_tips.salvo.subtitle": "Наносить прямо на лоб",
    "quests.tfg_tips.salvo.desc": "&dМази&r — другой тип лекарств, наносимых на кожу. Они дают другие эффекты, например &cогнестойкость&r и &4мгновенное здоровье&r, но требуют сложной химии.",
    "quests.tfg_tips.salvo.task": "Любая мазь",
    
    //#endregion

    //#region Misc
    "quests.tfg_tips.misc.title": "Разные советы",
    "quests.tfg_tips.misc.subtitle": "Ещё больше советов!",
    "quests.tfg_tips.misc.desc": "Это разные советы, которые не подходят под другие категории, но всё равно полезно их знать.",

    "quests.tfg_tips.digger_helmet.title": "Шлем копателя",
    "quests.tfg_tips.digger_helmet.subtitle": "Для тех, кто копает целый день",
    "quests.tfg_tips.digger_helmet.desc.1": "&dШлем копателя&r — это шлем, который автоматически освещает окружающее пространство, освобождая руки! Полезно, если ваша главная рука занята, а в свободной руке щит. Для крафта потребуется немного &6Светящегося камня&r. Возможно, стоит отправиться в &4Подземелье&r за доступом в ранней игре...",
    "quests.tfg_tips.digger_helmet.desc.2": "&l&3Важно:&r&l Шлем копателя &dработает&r благодаря специальной настройке &cSodium Dynamic Lights&f, включите &b\"Dynamic Entity Lighting\"&f для корректной работы",

    "quests.tfg_tips.grappling_hook.title": "Крюк-кошкa",
    "quests.tfg_tips.grappling_hook.subtitle": "Это может плохо закончиться",
    "quests.tfg_tips.grappling_hook.desc": "Соединив 4 &aмотка верёвки&r и &bголовку кирки из кованого железа&r, вы можете создать &dКрюк-кошкy!&r Идеальный инструмент для подъёма на высокие горы, исследования больших пещер и перемещений по миру. В нём есть &esистема улучшений&r, позволяющая комбинировать и менять &dКрюк&r на ваш вкус.",

    "quests.tfg_tips.grapple_repair.title": "Ремонт крюка",
    "quests.tfg_tips.grapple_repair.subtitle": "ПРОЧИТАЙТЕ, ИНАЧЕ ПОЖАЛЕЕТЕ!",
    "quests.tfg_tips.grapple_repair.desc": "Все ваши &dулучшения крюка&r &aхранятся&r в виде NBT-данных внутри предмета. Это значит, что ремонт с помощью &cдругого&r Крюка-кошки &l&cУДАЛИТ все улучшения!&r\n\nВместо этого положите &dКрюк&r и немного &bпыли кованого железа&r в &3Верстак&r для ремонта.",

    "quests.tfg_tips.grapple_upgrades.title": "Улучшения крюка",
    "quests.tfg_tips.grapple_upgrades.subtitle": "Сбалансировано под TFG, конечно!",
    "quests.tfg_tips.grapple_upgrades.desc.1": "Улучшение &dКрюка&r происходит путём добавления или удаления предметов через &3Верстак&r.&r\n\nЧтобы увидеть все доступные улучшения, нажмите клавишу \"Использование\" в &2EMI.&r\nКаждый рецепт содержит описание изменений.",
    "quests.tfg_tips.grapple_upgrades.desc.2": "Улучшения можно убрать, скрафтив &dКрюк&r с &bМолотом&r и &апредметом, использованным для улучшения&r (предмет не будет потрачен). Крафт вернёт &dКрюк&r без улучшения и исходный предмет, то есть вы получите два предмета обратно! По умолчанию так происходит удаление всех улучшений, если не указано иначе в соответствующем квесте.\n\n&lУлучшения нельзя накладывать друг на друга: чтобы заменить мотор &7LV&f на &bMV&f, сначала нужно удалить мотор &7LV&f.",


    "quests.tfg_tips.grapple_length.title": "Grappling Hook Upgrade: Длина",
    "quests.tfg_tips.grapple_length.subtitle": "Длинный парень",
    "quests.tfg_tips.grapple_length.desc": "По умолчанию у вашего &dКрюка&r длина &b80 блоков&r, вы можете добавить &cеще 20&r, добавив больше &aКатушек с веревкой.&r Максимум — 200 блоков.\n\nДлину можно &3уменьшить&r, скрафтив с &aНожом&r, &2уменьшая на 20&r, до минимума в 20.",
  
    "quests.tfg_tips.grapple_motor.title": "Grappling Hook Upgrade: Мотор",
    "quests.tfg_tips.grapple_motor.subtitle": "Ленивый, да?",
    "quests.tfg_tips.grapple_motor.desc": "&aМодуль мотора&r позволяет автоматически подтягивать &dКрюк.&r Будьте осторожны, &cмоторы высокого уровня&r могут вызвать &4урон от падения&r из-за силы подтягивания.\n\nМоторы делятся на уровни по &2Gregtech&r напряжениям. Рецепт крафта показывает, какие характеристики и насколько были изменены.",
  
    "quests.tfg_tips.grapple_smart_motor.title": "Grappling Hook Upgrade: Умный Мотор",
    "quests.tfg_tips.grapple_smart_motor.subtitle": "Кто вообще понимает, что это делает?",
    "quests.tfg_tips.grapple_smart_motor.desc": "&aУмный Мотор&r активирует &3систему Умного Мотора&r. Требует предварительной установки &bМодуля мотора.&r",
  
    "quests.tfg_tips.grapple_field.title": "Grappling Hook Upgrade: Поле Отталкивания",
    "quests.tfg_tips.grapple_field.subtitle": "Смотри, мама! Я левитирую!",
    "quests.tfg_tips.grapple_field.desc": "&aМодуль поля отталкивания&r отталкивает вас от близлежащих блоков. Будьте осторожны, &cсильные поля отталкивания&r могут вызвать &4урон от падения&r.\n\nПоля отталкивания делятся на уровни по &2Gregtech&r напряжениям. Рецепт крафта показывает, какие характеристики и насколько были изменены.",
  
    "quests.tfg_tips.grapple_magnet.title": "Grappling Hook Upgrade: Магнит Крюка",
    "quests.tfg_tips.grapple_magnet.subtitle": "Интенсивное притяжение",
    "quests.tfg_tips.grapple_magnet.desc": "&aМодуль Магнита&r притягивает ваш &dКрюк&r к любым близлежащим блокам, цепляясь за них.\n\nМагниты делятся на уровни с использованием &2магнитных слитков Gregtech&r, от худшего &bМагнитного железа&r до лучшего &bМагнитного самария.&r",
    "quests.tfg_tips.grapple_magnet.task": "Любой магнитный слиток",
  
    "quests.tfg_tips.grapple_sticky.title": "Grappling Hook Upgrade: Липкая Веревка",
    "quests.tfg_tips.grapple_sticky.subtitle": "Липкая!",
    "quests.tfg_tips.grapple_sticky.desc": "&aМодуль Липкой Веревки&r цепляет ваш &dКрюк&r к любой части веревки, касающейся блока.",
  
    "quests.tfg_tips.grapple_throw_speed.title": "Grappling Hook Upgrade: Скорость Метания",
    "quests.tfg_tips.grapple_throw_speed.subtitle": "Вжух!",
    "quests.tfg_tips.grapple_throw_speed.desc": "&aМодуль скорости метания&r ускоряет запуск вашего &dКрюка&r.\n\nМодули скорости делятся на уровни по &2Gregtech&r напряжениям. Рецепт крафта показывает, какие характеристики и насколько были изменены.",
  
    "quests.tfg_tips.grapple_double.title": "Grappling Hook Upgrade: Двойной Крюк",
    "quests.tfg_tips.grapple_double.subtitle": "Двойное веселье!",
    "quests.tfg_tips.grapple_double.desc": "&aМодуль двойного крюка&r позволяет метать &dдва крюка&r под углом. Можно назначить отдельные клавиши для каждого крюка.",
  
    "quests.tfg_tips.grapple_gravity_50.title": "Grappling Hook Upgrade: 0.5 Гравитации",
    "quests.tfg_tips.grapple_gravity_50.subtitle": "Это вообще имеет смысл?",
    "quests.tfg_tips.grapple_gravity_50.desc": "&aМодуль 0.5 гравитации&r задает вашему крюку &bКоэффициент гравитации 0.5.&. Это значит, что на него действует гравитация в половинном размере!\n\nВместо использования другого &dВедра с гелием&r для удаления модуля, используйте &cПустое ведро&r. Оно заполнится &eгелием&r, который вы использовали.",
  
    "quests.tfg_tips.grapple_gravity_0.title": "Grappling Hook Upgrade: НУЛЕВАЯ гравитация",
    "quests.tfg_tips.grapple_gravity_0.subtitle": "Довольно дорого",
    "quests.tfg_tips.grapple_gravity_0.desc": "&aМодуль НУЛЕВОЙ гравитации&r, как видно из названия, отменяет гравитацию для вашего крюка.\n\nВместо другого Модуля гравитационного двигателя &cдля удаления&r используйте &dВольфрамовый блок&r.",
  
    "quests.tfg_tips.grapple_tweaks.title": "Grappling Hook Upgrade: Настройки",
    "quests.tfg_tips.grapple_tweaks.subtitle": "Настройка углов",
    "quests.tfg_tips.grapple_tweaks.desc": "Используя &aГаечный ключ&r, вы можете настраивать &bугол вверх&r при метании &dКрюка&r, а &aОтвертка&r регулирует &bгоризонтальный угол&r &aМодуля двойного крюка.&r",
  
    "quests.tfg_tips.chalk.title": "Мел",
    "quests.tfg_tips.chalk.subtitle": "Ты же не хочешь заблудиться, правда?",
    "quests.tfg_tips.chalk.desc": "&dМел&r можно использовать, чтобы рисовать разные символы на блоках. Он очень полезен для отметки важных мест при &bисследовании пещер.&r\n\n&3Коробка с мелом&r может хранить несколько кусочков мела в одном слоте. Более того, можно добавить светящийся предмет (например, &6Светокамень&r), чтобы ваши рисунки светились в темноте!",
  
    "quests.tfg_tips.tape_measure.title": "Рулетка",
    "quests.tfg_tips.tape_measure.subtitle": "Хватит считать блоки вручную",
    "quests.tfg_tips.tape_measure.desc": "Вы можете использовать &dРулетку&r для измерения периметра или длины, особенно при больших проектах. Просто кликните на блок с рулеткой в руке, чтобы начать измерять. Чтобы закончить, кликните правой кнопкой на другом блоке.",
  
    "quests.tfg_tips.blank_disc.title": "Etched: Слушай музыку",
    "quests.tfg_tips.blank_disc.subtitle": "Слушай свои треки, пока занимаешься Gregtech.",
    "quests.tfg_tips.blank_disc.desc": "&2Etched&r — музыкальный мод, который позволяет играть музыкальные диски новыми способами, включая &dпользовательские диски&r, которые воспроизводят любую песню (например, с Bandcamp, Soundcloud), а также &aзвуки внутри игры&r через звуковые события.\n\nЧтобы начать с &2Etched&r, скрафтьте &bПустой Музыкальный Диск.&r",
  
    "quests.tfg_tips.radio.title": "Радио",
    "quests.tfg_tips.radio.subtitle": "Слушай музыку без дисков",
    "quests.tfg_tips.radio.desc": "&dРадио&r позволяет запросить любую песню. Кликните по нему и введите желаемую песню, например, URL или звуковое событие Minecraft.",
  
    "quests.tfg_tips.dye_discs.title": "Классика",
    "quests.tfg_tips.dye_discs.subtitle": "Они никогда не устареют...",
    "quests.tfg_tips.dye_discs.desc": "Погружая &bПустой Диск&r в &aБочку&r с красителем, вы можете создать классические диски из ванильной игры. Наслаждайтесь хитами, такими как &dWait, 13&r и &dBlocks!&r",
    "quests.tfg_tips.dye_discs.task": "Любой классический диск",
  
    "quests.tfg_tips.special_discs.title": "Уникальные",
    "quests.tfg_tips.special_discs.subtitle": "Они уникальны... Или были такими, по крайней мере",
    "quests.tfg_tips.special_discs.desc": "Вы также можете скрафтить &dУникальные диски&r, если хотите...",  

    "quests.tfg_tips.disc_collector.title": "Собиратель Дисков",
    "quests.tfg_tips.disc_collector.subtitle": "Полная коллекция",
    "quests.tfg_tips.disc_collector.desc": "Сможешь ли ты создать все музыкальные диски?\n\nРаз уж ты здесь, то знай — есть 2 скрытых задания, связанных с музыкальными дисками. Одно довольно &cподозрительное&r, а другое может потребовать, чтобы ты пробудил в себе внутреннего дворфа. Удачи!",
  
    "quests.tfg_tips.amogus.title": "AMONGUS",
    "quests.tfg_tips.amogus.subtitle": "SUSSY BAKA!",
    "quests.tfg_tips.amogus.desc": "Поздравляем с разблокировкой этого скрытого, отвратительного задания. Пусть твоё вентилирование никто не заметит.",
  
    "quests.tfg_tips.label_album.title": "Лейблы и Альбомы",
    "quests.tfg_tips.label_album.subtitle": "Лейблы для твоих дисков и обложки альбомов, чтобы защитить их",
    "quests.tfg_tips.label_album.desc": "Чтобы &bначать гравировать&r свой первый диск, тебе понадобится &dЛейбл.&r Их, как и пустые диски, можно окрашивать.\n\n&dОбложки Альбомов&r используются для покрытия выгравированных дисков. Если твой выгравированный диск получает данные с сайта вроде &cSoundcloud&r, иконка трека будет сжата до текстуры 16x16! Чтобы сохранить диск, открой инвентарь, выбери обложку альбома и щёлкни правой кнопкой мыши по нужному музыкальному диску. Также можно хранить обычные диски.",
  
    "quests.tfg_tips.etching_disc.title": "Гравировка первого диска",
    "quests.tfg_tips.etching_disc.subtitle": "Время для первой мелодии",
    "quests.tfg_tips.etching_disc.desc": "Чтобы начать &bгравировку,&r тебе понадобится &3Гравировальный Стол&r. Щелчок ПКМ по столу откроет интерфейс гравировки, и если положить туда &aПустой Диск&r с &aМузыкальной Меткой&r и подходящий источник звука в верхнюю панель, диск будет готов.\n\nИсточниками звука могут быть такие вещи, как &bссылки на Bandcamp/Soundcloud&r (на один трек или альбом), &dвнутриигровые звуковые события&r и пути к файлам &c.ogg/.wav/.mp3&r на твоём диске.\n\nЧтобы завершить это задание, выгравируй любой диск.",
  
    "quests.tfg_tips.disc_players.title": "Проигрыватели дисков",
    "quests.tfg_tips.disc_players.subtitle": "Чтобы, конечно же, проигрывать диски!",
    "quests.tfg_tips.disc_players.desc": "Можно использовать обычный &3Проигрыватель&r для воспроизведения музыки, но ты также можешь скрафтить следующие два предмета:\n\n&dАльбомный Проигрыватель&r: позволяет загружать несколько дисков и &bпереключаться между ними,&r идеально подходит для дома.\n\n&dБумбокс&r: позволяет брать музыку с собой в дорогу.",
    "quests.tfg_tips.disc_players.task": "Получить Альбомный Проигрыватель или Бумбокс",
  
    "quests.tfg_tips.DIGGY_DIGGY_HOLE.title": "Я ДВОРФ И КОПАЮ ЯМУ",
    "quests.tfg_tips.DIGGY_DIGGY_HOLE.subtitle": "КОПАЮ ЯМУ, КОПАЮ ЯМУ!",
    "quests.tfg_tips.DIGGY_DIGGY_HOLE.desc": "Поздравляем с разблокировкой этого скрытого, крутого задания. Пусть твои шахты никогда не обрушатся, а под землёй найдутся великие сокровища!",
    "quests.tfg_tips.DIGGY_DIGGY_HOLE.task": "Диск Diggy Diggy Hole",
  
    "quests.tfg_tips.camera.title": "Exposure: Запечатлей свои Воспоминания",
    "quests.tfg_tips.camera.subtitle": "Фотографируй свой мир",
    "quests.tfg_tips.camera.desc": "&2Exposure&r — это мод, добавляющий реалистичную обработку фотографий в игру. Начни с создания &bКамеры&r и &aПлёнок,&r а затем прояви свои снимки! В моде есть сложные системы, такие как цветокоррекция, фильтры и многое другое.",
  
    "quests.tfg_tips.selfie.title": "Селфи",
    "quests.tfg_tips.selfie.subtitle": "Для соцсетей!",
    "quests.tfg_tips.selfie.desc": "Когда у тебя открыта &bКамера&r, нажми F5, чтобы включить &bРежим Селфи&r, который, как ясно из названия, позволяет делать автопортреты.",
  
    "quests.tfg_tips.camera_attachments.title": "Аксессуары для Камеры",
    "quests.tfg_tips.camera_attachments.subtitle": "Улучшай свою Камеру",
    "quests.tfg_tips.camera_attachments.desc": "При взаимодействии с &dКамерой&r в режиме приседания откроется её GUI. Это позволяет не только вставить нужную &aПлёнку,&r но и прикрепить дополнения с новыми функциями.\n\n&dРедстоун-Лампа&r: работает как фонарик, освещая тёмные места.\n&dПодзорная Труба&r: позволяет приближать, чтобы делать снимки объектов на расстоянии.",
    "quests.tfg_tips.camera_attachments.task": "Редстоун-Лампа или Подзорная Труба",
  
    "quests.tfg_tips.filters.title": "Цветовые Фильтры",
    "quests.tfg_tips.filters.subtitle": "Измени вид своих фотографий",
    "quests.tfg_tips.filters.desc": "Используя &aСтеклянную Панель,&r ты можешь применить к фотографии &dФильтр.&r Просто открой интерфейс камеры и вставь его в слот фильтра. С помощью &dФильтров&r можно изменить общую цветовую гамму снимков. Например, ты можешь сделать фото «холоднее», применив фильтр цвета &3Бирюзовый&r или &bСветло-Синий.&r",
    "quests.tfg_tips.filter.task": "Любая Стеклянная Панель",
  
    "quests.tfg_tips.interplanar_projector.title": "Межплановый Проектор",
    "quests.tfg_tips.interplanar_projector.subtitle": "Выглядит не очень реалистично...?",
    "quests.tfg_tips.interplanar_projector.desc": "&dМежплановый Проектор&r — это особый фильтр, который позволяет делать снимки &cвне&r мира Minecraft.\n\nТы можешь переименовать &aЛинзу&r в &3Столе Начертаний&r, указав имя, которое ведёт к изображению на твоём &bДиске&r или &bв Интернете.&r Установив линзу в &aКамеру&r и сделав снимок, ты получишь то самое внешнее изображение.",
  
    "quests.tfg_tips.film_rolls.title": "Плёнки",
    "quests.tfg_tips.film_rolls.subtitle": "Это не цифра",
    "quests.tfg_tips.film_rolls.desc": "Чтобы начать фотографировать, тебе нужно создать один из двух видов плёнки: &0Чёрно-Белую Плёнку&r и &dЦветную Плёнку.&r",
  
    "quests.tfg_tips.developing_film.title": "Проявка Плёнки",
    "quests.tfg_tips.developing_film.subtitle": "Представь, что ты принтер",
    "quests.tfg_tips.developing_film.desc": "После того как ты сделал снимки, можно начать &aпроявку,&r замочив плёнку в &bВоде.&r Затем тебе нужно скрафтить &dФотолабораторию.&r\n\nФотолаборатория используется для проявки плёнки и требует сильного источника света сверху и следующих четырёх красителей: &3Бирюзового,&r &5Пурпурного,&r &eЖёлтого&r и &0Чёрного,&r известных как CMYK.\n&0Чёрно-Белая Плёнка&r требует только &0Чёрный Краситель,&r а &dЦветная Плёнка&r нуждается во всей палитре &3C&5M&eY&0K&r.\n\nЕсли тебе хочется более интересной обработки, поэкспериментируй с &cХроматической Обработкой...&r",
  
    "quests.tfg_tips.photo.title": "Твоя первая Фотография",
    "quests.tfg_tips.photo.subtitle": "Поздравляем!",
    "quests.tfg_tips.photo.desc": "С твоей &dФотографией&r ты можешь сделать многое:\n\nТы можешь её &bКопировать&r, используя чистый лист &aБумаги&r и нужные &aКрасители,&r использованные для оригинала.\n\nМожно также &bСложить&r фотографии в стопку для аккуратного хранения в инвентаре — проверь EMI, чтобы узнать как.\n\nТакже можно искусственно &cсостарить&r фото, добавив к нему &6Коричневый Краситель,&r чтобы оно выглядело прошедшим сквозь годы.",
  
    "quests.tfg_tips.photo_album.title": "Фотоальбом",
    "quests.tfg_tips.photo_album.subtitle": "Оказывается, воспоминания вечны...",
    "quests.tfg_tips.photo_album.desc": "Если тебе нужно место, чтобы &bхранить фотографии,&r сделай &dФотоальбом.&r Также ты можешь написать небольшие описания к каждому снимку в альбоме — укажи, где ты его сделал, добавь заметки и прочее!",
  
    "quests.tfg_tips.photo_frame.title": "Фоторамка",
    "quests.tfg_tips.photo_frame.subtitle": "Для самых поразительных фотографий",
    "quests.tfg_tips.photo_frame.desc": "&dФоторамка&r используется для показа снимков. В отличие от обычных Рамок, Фоторамки могут быть размером 1x1, 2x2 или 3x3, позволяя демонстрировать особенно красивые фото у себя на базе!",
    //#endregion

    //#region ArborFirmaCraft
    "quests.tfg_tips.arborfirmacraft.title": "ArborFirmaCraft",
    "quests.tfg_tips.arborfirmacraft.subtitle": "Сбор живицы из деревьев",
    "quests.tfg_tips.arborfirmacraft.desc": "&2ArborFirmaCraft&r — это мод, добавляющий множество новых деревьев в &3TFG&r: некоторые из них являются вариациями уже существующих деревьев из TFC, например, &dДревний Капок&r, а другие совершенно новые, такие как &aБаобаб&r и &aГевея.&r Некоторые текстуры досок и бревен этих деревьев могут напомнить тебе цвета ванильных деревьев...\n\nВ этом разделе будет рассмотрено &bСбор Живицы.&r\nВ качестве бонуса: вся древесина из &2ArborFirmaCraft&r совместима с &3FirmaLife&r и &3Firma:Civ&r — мы об этом позаботились!",
  
    "quests.tfg_tips.treetap.title": "Сборщик живицы",
    "quests.tfg_tips.treetap.subtitle": "Теперь с меньшим количеством костылей!",
    "quests.tfg_tips.treetap.desc": "Чтобы начать &bсобирать&r живицу с деревьев, тебе нужно выковать &dСборщик живицы&r, обработав &aМедные Слитки&r на &3Наковальне.&r\n\nДля сбора требуется подходящее дерево. Специальный &bИндекс для сбора&r в разделе &2Полевого Руководства&r из &3ArborFirmaCraft&r подскажет, какие деревья подходят. Также есть запись &bСбор живицы с деревьев&r, из которой ты узнаешь, как именно это делать.",
  
    "quests.tfg_tips.find_rosin_tree.title": "Смолистые деревья",
    "quests.tfg_tips.find_rosin_tree.subtitle": "Скоро станет прохладно...",
    "quests.tfg_tips.find_rosin_tree.desc": "&aСмолистые деревья&r встречаются в &9холодных&r районах мира с умеренным или сильным количеством осадков. Из них можно собирать &bСмоляную Живицу,&r которая используется для создания &dЛипкой Смолы&r и &dХвойной Смолы.&r\n\nЧтобы выполнить это задание, тебе нужно &cпосмотреть&r на блок с тегом &o#tfg:rosin_logs&r. С помощью EMI можно узнать, какие блоки имеют этот тег, выполнив поиск по этому хэштегу.",
  
    "quests.tfg_tips.find_latex_tree.title": "Латексные деревья",
    "quests.tfg_tips.find_latex_tree.subtitle": "Ищи в тропиках",
    "quests.tfg_tips.find_latex_tree.desc": "&aЛатексные деревья&r встречаются в &2умеренных&r районах мира с большим количеством осадков. Из них можно собирать &bЛатекс&r, который используется для создания &dЛипкой Смолы&r и &dВулканизированного Латекса.&r Последний нужен для производства &3Резины&r и &aРезиновых Перчаток,&r защищающих от &4ядовитых материалов&r при контакте.\n\nЧтобы выполнить это задание, тебе нужно &cпосмотреть&r на блок с тегом &o#tfg:latex_logs&r. С помощью EMI можно узнать, какие блоки имеют этот тег, выполнив поиск по этому хэштегу.",
  
    "quests.tfg_tips.find_syrup_tree.title": "Сиропные деревья",
    "quests.tfg_tips.find_syrup_tree.subtitle": "Диабет стремительно растёт",
    "quests.tfg_tips.find_syrup_tree.desc": "&aСиропные деревья&r встречаются в &2умеренных&r районах мира с умеренным количеством осадков. Из них можно собирать &bСироп.&r Сироп используется для создания &dДревесного Сахара&r — альтернативного подсластителя и не только.\n\nЧтобы выполнить это задание, тебе нужно &cпосмотреть&r на блок с тегом &o#tfg:syrup_logs&r. С помощью EMI можно узнать, какие блоки имеют этот тег.",
  
    "quests.tfg_tips.create_conifer_rosin.title": "Хвойная смола",
    "quests.tfg_tips.create_conifer_rosin.subtitle": "Нет, это не смола (Resin)",
    "quests.tfg_tips.create_conifer_rosin.desc": "&dХвойная Смола&r может использоваться как &bвоск,&r что позволяет создавать свечи и другие предметы.\n\nЧтобы получить хвойную смолу, нужно прокипятить &aХвойную Смоляную Живицу&r в &3Ванне&r, добавив &aУгольную Пыль.&r",
  
    "quests.tfg_tips.create_sticky_resin.title": "Липкая Смола",
    "quests.tfg_tips.create_sticky_resin.subtitle": "Нет, это не Хвойная Смола",
    "quests.tfg_tips.create_sticky_resin.desc": "&dЛипкая Смола&r может заменять слизь в некоторых рецептах. Она также необходима для производства &aСмоляных Микросхем&r и &aРезисторов,&r которые тебе предстоит активно использовать на этапе &7Низкого Напряжения.&r\n\nЧтобы сделать липкую смолу, прокипяти либо &aЛатекс,&r либо &aХвойную Смоляную Живицу&r в &3Ванне,&r добавив &aДревесную Золу.&r",
  
    "quests.tfg_tips.create_tree_sugar.title": "Древесный Сахар",
    "quests.tfg_tips.create_tree_sugar.subtitle": "Сладенько!",
    "quests.tfg_tips.create_tree_sugar.desc": "&dДревесный Сахар&r — это заменитель обычного сахара, в основном используется как пищевой ингредиент.\n\nЧтобы его получить, нужно прокипятить &aДревесный Сок&r, чтобы получить &bКонцентрированный Сок,&r затем снова прокипятить его, чтобы получить &dСироп.&r После этого используй верстак, чтобы превратить &bВедро Сиропа&r в &dДревесный Сахар.&r\nПомни, что все эти &cпроцессы кипячения требуют палку&r в &3Ванне&r или &3кастрюле.&r",
    "quests.tfg_tips.create_tree_sugar.task": "Сахар из клена или берёзы",
  
    "quests.tfg_tips.create_rubber_ingot.title": "Резиновый Слиток",
    "quests.tfg_tips.create_rubber_ingot.subtitle": "Изолируй провода",
    "quests.tfg_tips.create_rubber_ingot.desc": "С помощью &bВакуумной Камеры&r и дополнительного нагрева ты можешь переработать &aЛатекс&r из различных деревьев в &dСырой Резиновый Пульп&r через особый процесс. Затем ты можешь сплавить 3 &dСырого Резинового Пульпа&r с небольшим количеством &eСерной Пыли&r в &bПлавильне Сплавов,&r чтобы получить &dРезиновые Слитки&r, идеально подходящие для изоляции кабелей и крайне необходимые для прогресса в &2Вольтовом Веке&r и далее...",
    //#endregion

    //#region Transportation
    "quests.tfg_tips.transportation.title": "Транспорт",
    "quests.tfg_tips.transportation.subtitle": "Для путешествий по этому огромному миру",
    "quests.tfg_tips.transportation.desc": "Мир — очень большое место, и вам, возможно, придётся преодолевать большие расстояния в поисках ресурсов, необходимых для выживания и развития. Моды из этого раздела предоставят вам различные варианты передвижения.",
  
    "quests.tfg_tips.glider.title": "Дельтаплан",
    "quests.tfg_tips.glider.subtitle": "Это не Breath of the Wild",
    "quests.tfg_tips.glider.desc": "&dДельтаплан&r позволяет планировать по воздуху. Вы &cне сможете набирать высоту&r с его помощью, но он может быть полезен для преодоления больших расстояний, если прыгнуть с высоты.\nОтлично сочетается с &bРеактивными Ранцами&r!",
  
    "quests.tfg_tips.reinforced_glider.title": "Усиленный Дельтаплан",
    "quests.tfg_tips.reinforced_glider.subtitle": "Элитры использованы с умом...?",
    "quests.tfg_tips.reinforced_glider.desc": "Если вы объедините &aЭлитры&r, созданные на уровне &5EV&r, с &aДельтапланом&r, вы получите &dУсиленный Дельтаплан.&r Он обладает большей прочностью и более высокой максимальной скоростью.",
  
    "quests.tfg_tips.immersive_aircraft.title": "Immersive Aircraft",
    "quests.tfg_tips.immersive_aircraft.subtitle": "Летайте по небу со стилем.",
    "quests.tfg_tips.immersive_aircraft.desc": "&2Immersive Aircraft&r — мод, посвящённый воздушным аппаратам, позволяющим преодолевать большие расстояния по воздуху.",
  
    "quests.tfg_tips.aircraft_upgrades.title": "Улучшения Воздушных Аппаратов",
    "quests.tfg_tips.aircraft_upgrades.subtitle": "Прокачай мой аппарат",
    "quests.tfg_tips.aircraft_upgrades.desc": "&2Immersive Aircraft&r предлагает &aУлучшения&r для воздушных аппаратов, которые можно установить для повышения их характеристик: скорости, скорости взлёта, расхода топлива и т.д. Существует два типа улучшений: &bобычные&r и &dуровневые.&r\n\nВ этом квесте представлены &bобычные&r улучшения. Сможете собрать их все?",
  
    "quests.tfg_tips.steam_upgrades.title": "Улучшения Аппаратов: Пар",
    "quests.tfg_tips.steam_upgrades.subtitle": "Immersive Aircraft встречает GregTech!",
    "quests.tfg_tips.steam_upgrades.desc": "Второй тип улучшений — это &dУровневые Улучшения.&r Они соответствуют системе уровней &3Gregtech&r, начиная с &8Пара&r и до &5EV.&r\n\nПаровые улучшения — самые простые и ранние, требующие как минимум знания о &bЧёрной Стали.&r\n\n&dПаровые Двигатели для Воздушных Аппаратов&r используются при создании более сложных аппаратов, таких как &eБиплан&r и &cВоенный Корабль.&r",
    "quests.tfg_tips.steam_upgrades.task": "Любое улучшение парового уровня для воздушного аппарата",
  
    "quests.tfg_tips.lv_upgrades.title": "Улучшения Аппаратов: LV",
    "quests.tfg_tips.lv_upgrades.subtitle": "Красный и синий — в самый раз.",
    "quests.tfg_tips.lv_upgrades.desc": "Улучшения &7LV&r немного лучше паровых и требуют &4Красную&r и &9Синюю Сталь&r. Сам &dДвигатель LV&r требует настоящих &7LV&r компонентов.\n\n&3&lСовет:&r&o старые улучшения можно переработать с помощью &bДробильных Колёс&f, чтобы вернуть часть потраченных материалов.",
    "quests.tfg_tips.lv_upgrades.task": "Любое улучшение воздушного аппарата уровня Низкого Напряжения",
  
    "quests.tfg_tips.mv_upgrades.title": "Улучшения Аппаратов: MV",
    "quests.tfg_tips.mv_upgrades.subtitle": "Половина пути пройдена",
    "quests.tfg_tips.mv_upgrades.desc": "Улучшения &bMV&r — это середина пути, в их основе лежит &aАлюминий.&r\n\n&aАлюминиевые Роторы&r используются в большинстве воздушных аппаратов второго уровня, таких как &dГиродин, Военный Корабль&r и &dАлый Биплан,&r а &aДвигатель MV&r используется только в &dАлом Биплане.&r",
    "quests.tfg_tips.mv_upgrades.task": "Любое улучшение воздушного аппарата уровня Среднего Напряжения",
  
    "quests.tfg_tips.hv_upgrades.title": "Улучшения Аппаратов: HV",
    "quests.tfg_tips.hv_upgrades.subtitle": "Почти у цели",
    "quests.tfg_tips.hv_upgrades.desc": "Улучшения &6HV&r — предпоследний уровень, в их основе &aНержавеющая Сталь.&r",
    "quests.tfg_tips.hv_upgrades.task": "Любое улучшение воздушного аппарата уровня Высокого Напряжения",
  
    "quests.tfg_tips.ev_upgrades.title": "Улучшения Аппаратов: EV",
    "quests.tfg_tips.ev_upgrades.subtitle": "Эти компоненты вообще легальны?",
    "quests.tfg_tips.ev_upgrades.desc": "Улучшения &5EV&r — высший уровень улучшений воздушных аппаратов, в их основе лежит &aТитан.&r",
    "quests.tfg_tips.ev_upgrades.task": "Любое улучшение воздушного аппарата уровня Экстремального Напряжения",
  
    "quests.tfg_tips.aircraft_weapons.title": "Вооружение для Воздушных Аппаратов",
    "quests.tfg_tips.aircraft_weapons.subtitle": "Для великой ВАААГХ, само собой",
    "quests.tfg_tips.aircraft_weapons.desc": "Если вы хотите уничтожить что-то особенно опасное или покорить врагов, можно создать &dОружие,&r которое можно использовать для уничтожения или калечения мобов.\n\nКаждое оружие можно активировать с помощью &cКнопки Взаимодействия&r, находясь на &bАппарате.&r Большинство из них (кроме &aТелескопа&r) требует &aБоеприпасы.&r",
  
    "quests.tfg_tips.airship.title": "Дирижабль",
    "quests.tfg_tips.airship.subtitle": "Первый дирижабль малыша",
    "quests.tfg_tips.airship.desc": "&3Дирижабль&r — это воздушный аппарат, подходящий для путешествий. Однако его основное назначение — перевозка предметов.\nУ него есть &b16 Ячеек Инвентаря&r, &a3 Слота Улучшений&r и &c1 Слот для Оружия.&r",
  
    "quests.tfg_tips.cargo_airship.title": "Грузовой Дирижабль",
    "quests.tfg_tips.cargo_airship.subtitle": "Когда нужно перевезти всю базу на новое место",
    "quests.tfg_tips.cargo_airship.desc": "Прикрепите дополнительные &dДвигатели, Роторы&r и &d2 Деревянных Ящика&r, чтобы превратить &aДирижабль&r в &3Грузовой Дирижабль.&r\n\nОн &4расходует больше топлива&r, чем обычный.\nГрузовой Дирижабль имеет &b80 Ячеек Инвентаря&r и &a4 Слота Улучшений.&r",
  
    "quests.tfg_tips.waghship.title": "Военный Корабль",
    "quests.tfg_tips.waghship.subtitle": "Также известен как ВАААГХ-Корабль",
    "quests.tfg_tips.waghship.desc": "&3Военный Корабль&r — это финальное улучшение &aДирижабля&r. Он имеет &b66 Ячеек Инвентаря&r, &a6 Слотов Улучшений&r и &c2 Слота для Оружия.&r",
  
    "quests.tfg_tips.quadrocopter.title": "Квадрокоптер",
    "quests.tfg_tips.quadrocopter.subtitle": "Это не квадрокоптер",
    "quests.tfg_tips.quadrocopter.desc": "&3Квадрокоптер&r — очень простой &aАппарат на воздушной подушке,&r содержащий &b6 Ячеек Инвентаря,&r &aодин Слот Улучшения&r и &cодин Слот для Оружия.&r\n\nОн прост в управлении, что делает его идеальным для &eстроительства.&r",
  
    "quests.tfg_tips.gyrodyne.title": "Гиродин",
    "quests.tfg_tips.gyrodyne.subtitle": "Коптер на мускульной тяге",
    "quests.tfg_tips.gyrodyne.desc": "&3Гиродин&r — уникальный воздушный аппарат, не расходующий &dтопливо,&r а работающий исключительно на мускульной силе. Взамен он расходует вашу &4Сытость.&r\n\nИмеет &b18 Ячеек Инвентаря,&r &a3 Слота Улучшений&r и &c1 Слот для Оружия.&r",
  
    "quests.tfg_tips.economy_plane.title": "Эконом Самолёт",
    "quests.tfg_tips.economy_plane.subtitle": "Ваш первый самолёт... Так себе, конечно.",
    "quests.tfg_tips.economy_plane.desc": "&3Эконом Самолёт&r — самый простой &bСамолёт.&r Управляется с помощью &oтангажа&r и &oрысканья&r, в отличие от дирижаблей, ховеркрафтов и коптеров.\n\nИмеет &b4 Ячейки Инвентаря&r и &a4 Слота Улучшений.&r\nХотя он и медленный, &dЭконом Самолёт,&r как и дирижабль, может быть &2улучшен до более продвинутых моделей.&r",
  
    "quests.tfg_tips.biplane.title": "Биплан",
    "quests.tfg_tips.biplane.subtitle": "Почему он меньше, чем Эконом Самолёт?",
    "quests.tfg_tips.biplane.desc": "&3Биплан&r — это прямое улучшение &bЭконом Самолёта,&r создаётся из &aКорпусов, Паровых Котлов&r и &aУлучшенного Винта.&r\n\nИмеет &b16 Ячеек Инвентаря,&r &a4 Слота Улучшений&r и &c1 Слот для Оружия.&r В отличие от &dЭконом Самолёта,&r &3Биплан&r может быть &4ускорен с помощью ракет через специальный слот.&r",
  
    "quests.tfg_tips.scarlet_biplane.title": "Алый Биплан",
    "quests.tfg_tips.scarlet_biplane.subtitle": "Зрелище не для слабонервных",
    "quests.tfg_tips.scarlet_biplane.desc": "&3Алый Биплан&r — это финальное улучшение для &bСамолётов,&r требует компонентов уровня &6HV.&r\n\nИмеет &b27 Ячеек Инвентаря,&r &a4 Слота Улучшений,&r &c2 Слота для Оружия&r и также &4Слот для Ускорителей,&r как и обычный биплан.\n\nХотя и дорог, &3Алый Биплан&r компенсирует это увеличенной прочностью, максимальной скоростью и общим шикарным внешним видом.",
  
    "quests.tfg_tips.firmaciv.title": "Firma: Цивилизация",
    "quests.tfg_tips.firmaciv.subtitle": "Путешествуйте по морям со стилем.",
    "quests.tfg_tips.firmaciv.desc": "&2Firma: Civilization&r — мод, посвящённый лодкам и путешествиям по большим водоёмам. Также позволяет создавать инструменты, помогающие в навигации.",
  
    "quests.tfg_tips.firmaciv_info.title": "Путевые Штучки",
    "quests.tfg_tips.firmaciv_info.subtitle": "Если тебе важен реализм",
    "quests.tfg_tips.firmaciv_info.desc": "&3Firma:Civ&r поставляется с 4 различными навигационными инструментами, каждый из которых предоставляет важную информацию о вашем положении в мире.\nСюда входят: &dСекстант&r, &dНавигационные Часы&r, &dБарометр&r и &dКомпас&r; больше информации об инструментах в &2Полевом Руководстве.&r\n\n&3&lПредыстория:&r&o: Firma:Civ по умолчанию отключает координаты, чтобы вы пользовались навигационными инструментами. Мы не можем сделать это здесь, так что… используйте их, если хотите поиграть в ролевку.",
  
    "quests.tfg_tips.warfare.title": "Морская Война",
    "quests.tfg_tips.warfare.subtitle": "ОГОНЬ ИЗ ВСЕХ ОРУДИЙ!",
    "quests.tfg_tips.warfare.desc": "Вы можете вооружить свою &bШхуну&r с помощью &dПушки&r и ядер, если хотите превратить что-то в щепки.\nЧтобы выстрелить из пушки, нужно зарядить её &aПорохом, Неочищенной Бумагой&r и своим &aЯдром&r. Затем поджечь фитиль с помощью &cОгнива.&r",
  
    "quests.tfg_tips.kayak_beginning.title": "Лодка 1: Каяк",
    "quests.tfg_tips.kayak_beginning.subtitle": "Единственная переносимая лодка",
    "quests.tfg_tips.kayak_beginning.desc": "Каяк — относительно простая лодка для крафта, в ней помещается только один пассажир, но зато её можно носить с собой как предмет.",
  
    "quests.tfg_tips.kayak_materials.title": "Материалы для Каяка",
    "quests.tfg_tips.kayak_materials.subtitle": "Добудь себе этот Каяк.",
    "quests.tfg_tips.kayak_materials.desc": "Каяк — пожалуй, вторая по простоте лодка для создания. Тебе понадобится нечто вроде верёвки, немного пиломатериалов и Крупные Водонепроницаемые Шкуры. Эти шкуры можно получить с использованием Восков.",
  
    "quests.tfg_tips.create_kayak.title": "Создание Каяка",
    "quests.tfg_tips.create_kayak.subtitle": "Счастливого каякания!",
    "quests.tfg_tips.create_kayak.desc": "С Каяком перемещаться по небольшим водоёмам должно быть довольно просто. Обязательно создай весло, чтобы двигаться быстрее!",
  
    "quests.tfg_tips.entity_boats.title": "Сущностные Лодки",
    "quests.tfg_tips.entity_boats.subtitle": "А их нельзя с собой?",
    "quests.tfg_tips.entity_boats.desc": "Сущностные лодки отличаются от Каяка. Каяк можно переносить как предмет, а такие лодки как Весельные, Каноэ и Шхуны — нет. Зато у них есть преимущества: они могут вмещать нескольких пассажиров и \"Отсеки\" — например, Сундуки, Бочки и другие.\nЧтобы лодка не уплыла в закат, можно привязать её поводком. Возможно, стоит потратить время на строительство причала.\n\nСтоит отметить, что большинство лодок получают урон при проходе по жёстким препятствиям вроде Кораллов. Починить лодку можно с помощью древесины того же типа, из которого она сделана.",
  
    "quests.tfg_tips.beneathxfirmaciv.title": "Предупреждение: Beneath и Firma:Civ",
    "quests.tfg_tips.beneathxfirmaciv.subtitle": "Прочти это, иначе пожалеешь",
    "quests.tfg_tips.beneathxfirmaciv.desc": "Хотя ты можешь создать &aСущностные Лодки Firma:Civ&r из &dБагровых&r и &3Искажённых Стволов&r, лодки из этих огнестойких брёвен &4НЕ ЯВЛЯЮТСЯ&r устойчивыми к лаве! Если попытаешься переплыть лавовое озеро на такой лодке — &lутонешь&r и умрёшь ужасной смертью!",
  
    "quests.tfg_tips.canoe_beginning.title": "Лодка 2: Каноэ",
    "quests.tfg_tips.canoe_beginning.subtitle": "Примитивно",
    "quests.tfg_tips.canoe_beginning.desc": "Каноэ — тип лодки, в которую помещается один пассажир или один отсек. Делается из мягкой древесины и крафтится относительно просто — нужны лишь базовые инструменты и немного времени.",
  
    "quests.tfg_tips.canoe_materials.title": "Материалы для Каное",
    "quests.tfg_tips.canoe_materials.subtitle": "Проще не бывает",
    "quests.tfg_tips.canoe_materials.desc": "Нужно найти некий вид Мягкой Древесины. Полевое Руководство содержит список деревьев, подходящих для этого, а также процесс создания самого Каное.",
    "quests.tfg_tips.canoe_materials.task": "Любой Разжигатель Огня",
  
    "quests.tfg_tips.create_canoe.title": "Создание Каное",
    "quests.tfg_tips.create_canoe.subtitle": "Счастливого каноэния!",
    "quests.tfg_tips.create_canoe.desc": "С Каное перемещаться по средним водоёмам должно быть довольно просто. Обязательно создай весло, чтобы двигаться быстрее!\n\nЧтобы выполнить первое задание квеста, посмотри на любое готовое Каное.",
  
    "quests.tfg_tips.rowboat_beginning.title": "Лодка 3: Весельная",
    "quests.tfg_tips.rowboat_beginning.subtitle": "Уже работаешь с Кованым Железом?",
    "quests.tfg_tips.rowboat_beginning.desc": "Весельная лодка вмещает до четырёх отсеков или двух пассажиров и два отсека. Делается из твёрдой древесины и требует хотя бы базовых навыков обращения с Кованым Железом.",
  
    "quests.tfg_tips.rowboat_materials.title": "Материалы для Весельной Лодки",
    "quests.tfg_tips.rowboat_materials.subtitle": "Готовься к работе.",
    "quests.tfg_tips.rowboat_materials.desc": "Нужно найти некий вид Твёрдой Древесины. Полевое Руководство содержит список подходящих деревьев и процесс создания Весельной Лодки.\n\nИмей в виду: хотя первое задание принимает любые доски из твёрдой древесины, все доски должны быть одного типа! Попытка создать лодку из смешанной древесины не сработает!",
  
    "quests.tfg_tips.create_rowboat.title": "Создание Весельной Лодки",
    "quests.tfg_tips.create_rowboat.subtitle": "Счастливого весления!",
    "quests.tfg_tips.create_rowboat.desc": "С Весельной лодкой перемещаться по средним и крупным водоёмам будет легче. Обязательно сделай два весла, чтобы двигаться быстрее!\nТы также можешь покрасить свою лодку красителем на выбор!\n\nЧтобы выполнить первое задание, нужно посмотреть на готовую Весельную Лодку.",
  
    "quests.tfg_tips.sloop_beginning.title": "Лодка 4: Шхуна",
    "quests.tfg_tips.sloop_beginning.subtitle": "Хочешь вызова?",
    "quests.tfg_tips.sloop_beginning.desc": "Шхуна — это лодка. Самая большая и самая дорогая. В неё помещается 2 пассажира, но по палубе можно и ходить. Более того, в неё помещается до 12 отсеков! И это единственная лодка, в которую можно установить Пушки как Отсеки! Делается из твёрдой древесины и требует хотя бы базовых навыков работы со Сталью.",
  
    "quests.tfg_tips.sloop_under_construction_materials.title": "Материалы для Шхуны; Ч.1",
    "quests.tfg_tips.sloop_under_construction_materials.subtitle": "Теперь есть этапы?",
    "quests.tfg_tips.sloop_under_construction_materials.desc": "В отличие от Весельных Лодок и Каное, Шхуны создаются в два этапа: сначала строится \"Шхуна в Строительстве\", а затем она завершается в полноценную лодку.\nНужно найти некий вид Твёрдой Древесины. Полевое Руководство содержит список подходящих деревьев и процесс создания заготовки Шхуны.\n\nИмей в виду: хотя четвёртое задание принимает любые доски из твёрдой древесины, они все должны быть одного типа! Смешивать древесину нельзя!",
  
    "quests.tfg_tips.sloop_materials.title": "Материалы для Шхуны; Ч.2",
    "quests.tfg_tips.sloop_materials.subtitle": "Не переживай, частей только две.",
    "quests.tfg_tips.sloop_materials.desc": "Когда заготовка Шхуны завершена, можно собрать остальные материалы для финального этапа. Загляни в Полевое Руководство, если нужно больше информации.\n\nИмей в виду: первое, второе и третье задания принимают любые доски, брёвна и пиломатериалы из твёрдой древесины, но они все должны быть одного типа! Смешивать нельзя!",
  
    "quests.tfg_tips.create_sloop.title": "Создание Шхуны",
    "quests.tfg_tips.create_sloop.subtitle": "Где Ветер Времени, когда он так нужен?",
    "quests.tfg_tips.create_sloop.desc": "С Шхуной перемещаться по большим водоёмам будет проще. Чтобы не быть на милости ветра, можно опустить Якорь и остановиться.\nТы также можешь покрасить свою лодку в любой цвет с помощью красителя!\n\nЧтобы выполнить задание, посмотри на готовую Шхуну.",
  
    "quests.tfg_tips.fishing_net.title": "Рыболовные Сети",
    "quests.tfg_tips.fishing_net.subtitle": "Не носки, увы.",
    "quests.tfg_tips.fishing_net.desc": "Рыбу ещё никогда не было так просто ловить. Всего одно ПКМ — и ужин готов.",
    "quests.tfg_tips.fishing_net.task": "Любой #forge:tools/fishing_nets",
    //#endregion

    //#region Firmalife
    "quests.tfg_tips.firmalife.title": "Firmalife",
    "quests.tfg_tips.firmalife.subtitle": "Процветайте в TerraFirmaCraft",
    "quests.tfg_tips.firmalife.desc": "&2Firmalife&r — мод, расширяющий сельское хозяйство и гастрономический опыт в TerraFirmaCraft, дополняя это разнообразными дополнительными функциями. Включает украшения, новые методы консервирования, новые виды пищи, пчёл и множество полезных приспособлений!",
  
    "quests.tfg_tips.greenhouse.title": "Теплица",
    "quests.tfg_tips.greenhouse.subtitle": "Выращивайте урожай круглосуточно!",
    "quests.tfg_tips.greenhouse.desc": "&dТеплица&r — это сложная многоблочная структура с несколькими уровнями, предназначенная для круглогодичного выращивания урожая ценой снижения урожайности. Подробнее читайте в &2Полевом Руководстве&r!",
  
    "quests.tfg_tips.beekeeping.title": "Пчеловодство",
    "quests.tfg_tips.beekeeping.subtitle": "Теперь они такие маленькие...",
    "quests.tfg_tips.beekeeping.desc": "&bПчеловодство&r имеет массу применений. Пчёлы опыляют окружающие посевы (если у них есть нужная черта), а также дают полезные ресурсы, такие как &aВоск&r и &aМёд.&r Разводите пчёл для улучшения их характеристик.\nПодробности обо всех механиках &bпчеловодства&r есть в &2Полевом Руководстве&r.",
  
    "quests.tfg_tips.beehive.title": "Пчелиный улей",
    "quests.tfg_tips.beehive.subtitle": "Пора полагаться на удачу...",
    "quests.tfg_tips.beehive.desc": "Чтобы начать путь пчеловода, вам потребуется и &bПчелиный улей&r, и &aРамка для улья.&r\nВ отличие от обычного Minecraft, ульи не появляются естественно — пчёлы появляются только в &bПчелиных ульях&r, созданных игроком, если рамки заселены &eМатками.&r Шанс заселения зависит от удачи, но его можно повысить, разместив вокруг улья &dцветы&r.\n\nКогда рамка будет заселена, начнётся появление пчёл, которые будут производить мёд.",
  
    "quests.tfg_tips.not_the_bees.title": "Броня пчеловода",
    "quests.tfg_tips.not_the_bees.subtitle": "НЕ ПЧЁЛЫ!",
    "quests.tfg_tips.not_the_bees.desc": "Пчёлам не нравится, когда кто-то мешает им и забирает их мёд и воск. Есть три способа делать это безопасно:\n\n* &dСобирать ночью&r\n* &dИспользовать костёр&r\n* &dИспользовать броню пчеловода&r",
    "quests.tfg_tips.not_the_bees.task": "Я воспользуюсь костром или подожду наступления ночи.",
  
    "quests.tfg_tips.honey.title": "Мёд",
    "quests.tfg_tips.honey.subtitle": "Ох, ну и липко...",
    "quests.tfg_tips.honey.desc": "С помощью &aПустой банки&r, сделанной методом &bвыдувания стекла&r, можно кликнуть ПКМ по улью с мёдом и получить &dБанку мёда.&r Мёд — отличный заменитель сахара.",
  
    "quests.tfg_tips.beeswax.title": "Пчелиный воск",
    "quests.tfg_tips.beeswax.subtitle": "Достойная жертва",
    "quests.tfg_tips.beeswax.desc": "Если кликнуть ПКМ по &aРамке&r с &bМаткой&r, держа &cНож&r, рамка очистится, матка погибнет, и вы получите &dВоск.&r\n\n&3&lСовет:&r&o можно жертвовать &bМатками&f с плохими чертами, чтобы стимулировать разведение с лучшими характеристиками — пустая рамка заполнится потомством с чертами других маток.",
  
    "quests.tfg_tips.candles.title": "Свечи",
    "quests.tfg_tips.candles.subtitle": "Уютно...",
    "quests.tfg_tips.candles.desc": "Свечи можно создать из &aПарафинового воска, Пчелиного воска&r или &aКанифоли.&r\nСвечи — лучший источник света по сравнению с факелами: они горят 1 месяц и 2 дня.",
  
    "quests.tfg_tips.oven.title": "Печь",
    "quests.tfg_tips.oven.subtitle": "Осторожно, горячо",
    "quests.tfg_tips.oven.desc": "&3Печь&r — это многоблочная структура для удобной готовки еды и выполнения уникальных рецептов. Обязательные части: &aНижняя часть, Верхняя часть&r и &aДымоход.&r Не забудьте про &dЛопату для печи&r, чтобы доставать еду из &aВерхней части.&r\nКак построить &3Печь&r — в &2Полевом Руководстве.&r\n\n&3&lСовет:&r&o Единственное блюдо, покрывающее все 5 групп питательных веществ, &cПицца&f, готовится именно в печи.",
  
    "quests.tfg_tips.oven_appliances.title": "Печные устройства",
    "quests.tfg_tips.oven_appliances.subtitle": "Больше пользы от вашей печи",
    "quests.tfg_tips.oven_appliances.desc": "&3Печные устройства&r — это опциональные блоки, которые размещаются сверху &aНижней части печи&r для получения тепла. Можно иметь &cmножество&r &aНижних частей&r в одном мультиблоке.\n\n&dЖелезная решётка&r: ускоряет готовку и увеличивает срок хранения.\n&dЧан&r: варит рецепты в горшках массово! Полезен для &eЛатекса&r и &aДжема.&r\n&dСтанция консервирования&r: ставится рядом с &bЧаном&r, заполняет банки &aДжемом.&r\n&dГоршок&r: используется для готовки супов.",
  
    "quests.tfg_tips.oven_finish.title": "Отделка печи",
    "quests.tfg_tips.oven_finish.subtitle": "Эстетика",
    "quests.tfg_tips.oven_finish.desc": "Если вам не нравится вид глиняного кирпича, вы можете нанести &bОтделку&r на компоненты печи, чтобы изменить её внешний вид.",
    "quests.tfg_tips.oven_finish.task": "Любая отделка печи",
  
    "quests.tfg_tips.oven_utils.title": "Дополнения для печи",
    "quests.tfg_tips.oven_utils.subtitle": "Полезные вещи",
    "quests.tfg_tips.oven_utils.desc": "&dЗольник&r, размещённый под &aНижней частью печи&r, может собирать &cДревесную золу&r от горящих брёвен. Кликните ПКМ, чтобы её достать.\n\n&dПечной загрузчик&r: подаёт брёвна в &bНижнюю часть печи&r, на которую направлен — полезно для автоматизации.",
  
    "quests.tfg_tips.jam.title": "Джем",
    "quests.tfg_tips.jam.subtitle": "Не варенье",
    "quests.tfg_tips.jam.desc": "&dДжем&r — отличный способ сохранить фрукты: &bЗапечатанная банка с джемом&r может храниться до &cдвух лет&r без открытия.\n\nДля розлива джема потребуется &aБанка с крышкой&r, для которой нужны &bВыдувание стекла&r (банка) и &bКузнечное дело&r (крышки).\n\n&3&lСовет:&r&l &aGT-машины&f в будущем упростят производство этих компонентов.",
  
    "quests.tfg_tips.preservation.title": "Дерево Консервации",
    "quests.tfg_tips.preservation.subtitle": "Как продлить срок хранения еды",
    "quests.tfg_tips.preservation.desc": "Гнилая еда непригодна к употреблению (но ею можно кормить свиней!). Чтобы процветать в &2TFG&r, придётся искать способы продлить срок хранения еды как можно дольше.\n\nДрево заданий выше раскрывает несколько методов консервации разных продуктов. Обратите внимание: иконки с гнилой едой — лишь визуальный баг.\n\n&3&lСовет:&r&o все модификаторы срока хранения &dсуммируются&f, позволяя добиться огромного срока хранения.",
  
    "quests.tfg_tips.brine_something.title": "Засолка",
    "quests.tfg_tips.brine_something.subtitle": "Подготовительный шаг к другим способам консервации",
    "quests.tfg_tips.brine_something.desc": "Засолка &aсырого мяса, овощей&r или &aфруктов&r требует &dРассола&r, который делается из &bМорской воды&r и &bУксуса.&r Это предварительный шаг перед &3маринованием&r и &3копчением.&r",
    "quests.tfg_tips.brine_something.task.1": "Засоленное мясо, овощ или фрукт.",
    "quests.tfg_tips.brine_something.task.2": "Ведро рассола",
  
    "quests.tfg_tips.pickle_something.title": "Общая консервация: Маринование",
    "quests.tfg_tips.pickle_something.subtitle": "Общая консервация №3",
    "quests.tfg_tips.pickle_something.desc": "Маринование &aсырого мяса, овощей&r или &aфруктов&r. После &3засолки&r продукт маринуется в бочке, полной &aУксуса.&r Пока бочка запечатана, продукт получает модификатор &dМаринованный&r, значительно продлевающий срок хранения.",
    "quests.tfg_tips.pickle_something.task.1": "Ведро уксуса",
    "quests.tfg_tips.pickle_something.task.2": "Маринованное мясо, овощ или фрукт.",
  
    "quests.tfg_tips.get_milk.title": "Консервация молока",
    "quests.tfg_tips.get_milk.subtitle": "Есть молоко?",
    "quests.tfg_tips.get_milk.desc": "&dМолоко&r можно получить от 3 животных: &aКоров, Коз&r и &aЯков.&r\nМолоко можно пить, чтобы восполнить &bМолочные продукты&r, либо перерабатывать в сыр.\n\nДля выполнения задания возьмите ведро с любым молоком.",
    "quests.tfg_tips.get_milk.task": "Любое ведро с молоком",
  
    "quests.tfg_tips.create_cheese.title": "Консервация молока: Сыр",
    "quests.tfg_tips.create_cheese.subtitle": "Сырно",
    "quests.tfg_tips.create_cheese.desc": "&aМолоко&r можно превратить в &dСырные головы&r, которые можно хранить в мире или нарезать с помощью &aНожа&r для получения &dЛомтиков сыра.&r\n\nКак делать сыр — в &2Полевом Руководстве.&r",
  
    "quests.tfg_tips.cheese_aging.title": "Консервация молока: Созревание сыра",
    "quests.tfg_tips.cheese_aging.subtitle": "Воняет...",
    "quests.tfg_tips.cheese_aging.desc": "Построив &3Погреб&r, можно размещать там &aСырные головы&r для созревания. Это занимает время, но сильно увеличивает срок хранения. &lНе ломайте сыр руками — потеряете весь прогресс созревания!&r",
  
    "quests.tfg_tips.smoke_cheese.title": "Консервация молока: Копчение сыра",
    "quests.tfg_tips.smoke_cheese.subtitle": "Лучший вкус",
    "quests.tfg_tips.smoke_cheese.desc": "Можно подвесить &aЛомтик сыра&r на &bНитку&r над &cГорящим костром&r, чтобы его закоптить.",
    "quests.tfg_tips.smoke_cheese.task": "Ломтик копчёного сыра",
  
    "quests.tfg_tips.get_meat.title": "Консервация мяса",
    "quests.tfg_tips.get_meat.subtitle": "Не бей его",
    "quests.tfg_tips.get_meat.desc": "Большинство животных дают &aМясо&r — отличный источник белка, но в сыром виде оно быстро портится.\n\n&bСырое мясо&r можно &3засолить, замариновать&r и &3закоптить&r для наилучшего хранения, но это нужно сделать &cдо&r приготовления.",
  
    "quests.tfg_tips.salt_meat.title": "Консервация мяса: Соль",
    "quests.tfg_tips.salt_meat.subtitle": "Почти вяленое мясо",
    "quests.tfg_tips.salt_meat.desc": "&bЗасаливание&r мяса — быстрый и простой способ его сохранения. &dСоль&r можно получить из &aСолонцов&r, &aиндикаторов&r над соляными жилами, из &aсоляных жил&r или &aboлить&r морскую воду в &3Горшке.&r",
    "quests.tfg_tips.salt_meat.task": "Кусок солёного мяса",

    "quests.tfg_tips.smoke_meat.title": "Сохранение Мяса: Копчение",
    "quests.tfg_tips.smoke_meat.subtitle": "С дымком",
    "quests.tfg_tips.smoke_meat.desc": "Вы можете повесить до 8 кусков &aСырого Мяса&r на &bВерёвку&r, расположенную над &cГорящим Костром&r, чтобы закоптить их. Имейте в виду, что мясо &lдолжно быть предварительно засолено в рассоле.&r \nТакже его можно &dпосолить&r перед копчением.",
    "quests.tfg_tips.smoke_meat.task": "Кусок Копчёного Мяса",
  
    "quests.tfg_tips.cook_meat.title": "Сохранение Мяса: Готовка",
    "quests.tfg_tips.cook_meat.subtitle": "Теперь это кажется очевидным.",
    "quests.tfg_tips.cook_meat.desc": "Готовка может сама по себе дать свойства консервации. Вы должны готовить &aМясо&r либо на &bЖелезной Решётке&r, либо в &bВерхней Печи!&r\nДругие методы готовки могут вовсе не давать никаких свойств или даже ухудшать срок хранения.\n\n&3&lСовет:&r&o &bЖелезные Решётки&r могут быть частью конструкции &dПечи&f.",
    "quests.tfg_tips.cook_meat.task.1": "Кусок Жареного или Запечённого Мяса.",
    "quests.tfg_tips.cook_meat.task.2": "Железная Решётка или Верхняя Печь",
  
    "quests.tfg_tips.get_veggie.title": "Сохранение Овощей",
    "quests.tfg_tips.get_veggie.subtitle": "Полезны для здоровья",
    "quests.tfg_tips.get_veggie.desc": "&aОвощи&r в основном собираются в дикой природе или выращиваются на фермах. Они могут быть только &bМаринованы.&r",
  
    "quests.tfg_tips.get_fruit.title": "Сохранение Фруктов",
    "quests.tfg_tips.get_fruit.subtitle": "Вкуснятина!",
    "quests.tfg_tips.get_fruit.desc": "&aФрукты&r в основном собираются в дикой природе, с &bДеревьев, Кустов&r, а также при нарезке &bДынь&r и &bТыкв.&r В отличие от овощей, у фруктов есть уникальный способ консервации: &dсушка&r, в дополнение к &bмаринованию.&r\n&cСушёные фрукты необходимы&r для получения вашего первого &dДрожжевого&r гриба.",
  
    "quests.tfg_tips.dry_fruit.title": "Сохранение Фруктов: Сушка",
    "quests.tfg_tips.dry_fruit.subtitle": "Воды почти нет",
    "quests.tfg_tips.dry_fruit.desc": "С помощью &3Сушильного Коврика&r вы можете сушить фрукты, увеличивая срок их хранения. Более продвинутый вариант — это &3Солнечная Сушилка&r.",
    "quests.tfg_tips.dry_fruit.task.1": "Сушёный Фрукт",
    "quests.tfg_tips.dry_fruit.task.2": "Сушильный Коврик или Солнечная Сушилка",
  
    "quests.tfg_tips.get_grain.title": "Сохранение Зерна",
    "quests.tfg_tips.get_grain.subtitle": "Углеводы",
    "quests.tfg_tips.get_grain.desc": "&aЗерновые&r культуры довольно легко вырастить локально. Хотя обычное необработанное зерно может быстро портиться, есть способы значительно продлить его срок хранения.",
    "quests.tfg_tips.get_grain.task": "Любое Зерно",
  
    "quests.tfg_tips.process_grain.title": "Сохранение Зерна: Обработка Ножом",
    "quests.tfg_tips.process_grain.subtitle": "Проще простого.",
    "quests.tfg_tips.process_grain.desc": "Создав &aЗерновые Культуры&r с помощью Ножа в Верстаке, вы получите само &dЗерно&r, которое долго хранится, а также немного соломы.",
  
    "quests.tfg_tips.passive_preservation.title": "Пассивное Хранение",
    "quests.tfg_tips.passive_preservation.subtitle": "Хранить еду на полу — не лучшая идея",
    "quests.tfg_tips.passive_preservation.desc": "Существует несколько способов дольше сохранять еду во время хранения. Три из них указаны выше и считаются отличными вариантами.",
  
    "quests.tfg_tips.vessel_preservation.title": "Общее Хранение: Сосуды",
    "quests.tfg_tips.vessel_preservation.subtitle": "Лучше, чем просто рюкзаки.",
    "quests.tfg_tips.vessel_preservation.desc": "Помещение еды в &aСосуд&r или &aБольшой Сосуд&r (не забудьте запечатать второй) даёт ей свойство &dГерметичности&r, увеличивая срок хранения в дороге. Идеально для путешествий!",
  
    "quests.tfg_tips.cellar.title": "Погреб",
    "quests.tfg_tips.cellar.subtitle": "Мамин Подвал",
    "quests.tfg_tips.cellar.desc": "&3Погреб&r — это мультиблочная структура, используемая для долгосрочного хранения еды. Пища здесь должна храниться на &aПолках&r и &aПодвесных Крючках.&r В нём также можно &bсозревать сыр&r.\nОзнакомьтесь с &2Полевым Руководством&r, чтобы узнать, как построить &3Погреб.&r",
    "quests.tfg_tips.cellar.task": "Любая форма герметичного входа.",
  
    "quests.tfg_tips.refrigerator.title": "Холодильник",
    "quests.tfg_tips.refrigerator.subtitle": "Возможно, он слишком хорош",
    "quests.tfg_tips.refrigerator.desc": "Если вы достигли &7LV&r эпохи, вы можете создать &dХолодильник&r, который потребляет энергию в обмен на &olучшее&r универсальное свойство хранения для всех типов пищи. Это включает в себя сырую, приготовленную и комбинированную еду, такую как сэндвичи.",
  
    "quests.tfg_tips.cellar_blocks.title": "Хранение в Погребе",
    "quests.tfg_tips.cellar_blocks.subtitle": "Куда положить еду",
    "quests.tfg_tips.cellar_blocks.desc": "&bПолки&r можно использовать для хранения практически любой еды. &bКрючки&r позволяют вешать &aМясо&r и &aЧеснок.&r Пища, хранящаяся таким образом, получает очень мощное свойство хранения, превосходящее даже &dСосуды.&r",  
    //#endregion

    //#region Beneath
    "quests.tfg_tips.beneath.title": "Бездна",
    "quests.tfg_tips.beneath.subtitle": "Путешествие к центру Земли",
    "quests.tfg_tips.beneath.desc": "Глубоко, ОЧЕНЬ глубоко под землей, за &dБедроком&r, вы найдете &4Бездну&r — сеть гигантских пещер, полных опасностей, странной флоры и фауны. Хотя &4Бездна&r полностью необязательна, она содержит множество ресурсов и улучшений качества жизни.",

    "quests.tfg_tips.beneath_prep.title": "Подготовка",
    "quests.tfg_tips.beneath_prep.subtitle": "Бездна враждебна, подготовьтесь",
    "quests.tfg_tips.beneath_prep.desc": "&4Бездна&r — очень враждебная среда. Из-за большой глубины средняя температура здесь всегда &cвыше 15°C&r и увеличивается по мере углубления. И это не говоря уже о множестве враждебных существ, населяющих эти пещеры.\nЗадания, связанные с этим, дадут вам базовую подготовку к приключению.",

    "quests.tfg_tips.beneath_temp_management.title": "Управление температурой: Активное",
    "quests.tfg_tips.beneath_temp_management.subtitle": "Как быстро охладиться",
    "quests.tfg_tips.beneath_temp_management.desc": "В &4Бездне&r, где температура относительно высокая, стоит взять с собой &aВоду&r для охлаждения по требованию или &bСжатый Лёд&r, добытый в полярных регионах, если вы планируете обустроить временную базу.",

    "quests.tfg_tips.beneath_clothes.title": "Управление температурой: Пассивное",
    "quests.tfg_tips.beneath_clothes.subtitle": "Одежда для пассивного охлаждения",
    "quests.tfg_tips.beneath_clothes.desc": "&bОдежда&r также играет важную роль в охлаждении. Самая простая в изготовлении перед походом в &4Бездну&r — это &dМешковинная Одежда.&r\n\n&dШелковая Одежда&r требует &aНиток&r, которые можно найти в больших количествах в биоме Бездны под названием &cПаучье Логово.&r\n\nОднако есть и лучший вариант, если у вас есть доступ к &9Синей Стали&r...",

    "quests.tfg_tips.blue_steel_diving.title": "Снаряжение для Погружения из Синей Стали",
    "quests.tfg_tips.blue_steel_diving.subtitle": "Идеально для лавовых ванн",
    "quests.tfg_tips.blue_steel_diving.desc": "&9Снаряжение для Погружения из Синей Стали&r — это особый комплект брони, делающий вас полностью неуязвимым к &cЛаве&r, пока он надет. Его сниженное &aТепло&r, но высокая &bИзоляция&r обеспечивают стабильную температуру тела во время пребывания в &4Бездне.&r",

    "quests.tfg_tips.juicer.title": "Соковыжималка",
    "quests.tfg_tips.juicer.subtitle": "Гидратация в экстренной ситуации",
    "quests.tfg_tips.juicer.desc": "&3Соковыжималка&r — это особый предмет, который извлекает скрытую влагу из &aФруктов&r и &aГрибов&r, превращая её в питьевую &dВоду.&r\n\nВода чаще встречается на верхних уровнях &4Бездны&r. Чем ниже, тем она реже. Однако &aГрибы&r очень часто встречаются в &4Бездне&r, так что от жажды, надеемся, не умрете!",

    "quests.tfg_tips.how_to_go_beneath.title": "Как попасть в Бездну",
    "quests.tfg_tips.how_to_go_beneath.subtitle": "Обсидиан не нужен",
    "quests.tfg_tips.how_to_go_beneath.desc": "Чтобы попасть в &4Бездну&r, вам нужно встать на &bБедрок&r Поверхности и подождать несколько секунд — после этого вы будете &oтелепортированы&r вниз.\n\n&3&lСовет:&r&o Обязательно выкопайте достаточно большое пространство над бедроком в точке входа, чтобы при возвращении в Поверхность игра не закинула вас в случайную пещеру в поисках свободного места.",

    "quests.tfg_tips.how_to_go_beneath.task.1": "Доберитесь и встаньте на Бедрок",
    "quests.tfg_tips.how_to_go_beneath.task.2": "Посетите Бездну",

    "quests.tfg_tips.reach_the_beneath.title": "Добро пожаловать в Глубины",
    "quests.tfg_tips.reach_the_beneath.subtitle": "Также известные как Бездна",
    "quests.tfg_tips.reach_the_beneath.desc": "Как только вы окажетесь в &4Бездне&r, сразу создайте &cпутевую точку&r на карте, чтобы не потерять путь назад.\n\nВ отличие от ванильного Ада, здесь нет множителя расстояния 8x — не стоит использовать её для быстрого перемещения по Поверхности!",
    "quests.tfg_tips.reach_the_beneath.task": "Находиться в Бездне",

    "quests.tfg_tips.fuck_go_back.title": "Как выбраться из Бездны",
    "quests.tfg_tips.fuck_go_back.subtitle": "Мама, забери меня отсюда!",
    "quests.tfg_tips.fuck_go_back.desc": "Чтобы выбраться из &4Бездны&r, вам нужно добраться до верхних уровней пещер, ближе к &dПотолку из Бедрока.&r Постойте неподвижно несколько секунд рядом с потолком — и вас перенесёт обратно на &bПоверхность&r, в ту точку, откуда вы начинали.",

    "quests.tfg_tips.piglin_bartering.title": "Обмен с Пиглинами",
    "quests.tfg_tips.piglin_bartering.subtitle": "Похоже, мы тут не одни",
    "quests.tfg_tips.piglin_bartering.desc": "Любопытные обитатели &4Бездны&r могут предложить вам товары... Обменивайте золото на полезные ресурсы, такие как небольшое количество &aМеталлов&r или &aКожи.&r\nПодробности о торговле смотрите в &2Полевом Руководстве&r.",
    
    "quests.tfg_tips.piglin_disguise.subtitle": "Они никогда не узнают...",
    "quests.tfg_tips.piglin_disguise.desc": "Чувствуешь, что ты не на своём месте?\n На тебя нападают &4Пиглины&r в школе из-за твоей внешности?\n Попробуй надеть &aМаскировку Пиглина&r, чтобы избежать нежелательного внимания и слиться с толпой."
    //#endregion
}